{
  "name": "ai-security-brief",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "content:manifest": "node scripts/content-manifest.mjs --write",
    "check:content": "node scripts/content-manifest.mjs --check",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test:smoke": "node scripts/smoke-test.mjs",
    "verify:release": "pnpm check:content && pnpm typecheck && pnpm test:unit && pnpm test:smoke"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
