{
  "name": "ai-security-brief",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "content:manifest": "node scripts/content-manifest.mjs --write",
    "check:content": "node scripts/content-manifest.mjs --check",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test:smoke": "node scripts/smoke-test.mjs",
    "verify:ops": "node scripts/verify-ops.mjs",
    "verify:ops:contract": "node scripts/verify-ops.mjs --contract-only",
    "verify:release": "pnpm check:content && pnpm typecheck && pnpm test:unit && pnpm build && pnpm test:smoke",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "15.5.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.12",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0"
  }
}
