# ── Required for newsletter subscribe endpoint ──────────────────
# Get from Beehiiv dashboard → Settings → Integrations → API
BEEHIIV_API_KEY=bh_xxxxxxxxxxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Required for Vercel build / GitHub Actions ───────────────────
# These are set in Vercel project settings, not committed
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# ── Optional: override site URL (defaults to https://aithreatbrief.com) ──
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
